{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://desktop.local:11434/v1",
        "num_ctx": "65536"
      },
      "models": {
        "qwen3.5:4b": {
          "name": "qwen3.5:4b"
        },
        "qwen3.5:0.8b": {
          "name": "qwen3.5:0.8b"
        }
      }
    },
    "n8n": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "n8n (local)",
      "options": {
        "baseURL": "http://desktop.local:3333/v1",
        "headers": {
          "Authorization": "Bearer {env:N8N_API_KEY}"
        }
      },
      "models": {
        "ollama-postgres-v2": {
          "name": "ollama-postgres-v2"
        }
      }
    }
  }
}
